{
  "manifest_version": 3,
  "name": "ChessMark",
  "short_name": "ChessMark",
  "version": "0.1.3",
  "description": "Save Chess.com and Lichess board positions, notes, tags, screenshots, and FEN for later study.",
  "icons": {
    "16": "assets/icons/icon_16.png",
    "32": "assets/icons/icon_32.png",
    "48": "assets/icons/icon_48.png",
    "128": "assets/icons/icon_128.png"
  },
  "action": {
    "default_title": "ChessMark",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon_16.png",
      "32": "assets/icons/icon_32.png",
      "48": "assets/icons/icon_48.png",
      "128": "assets/icons/icon_128.png"
    }
  },
  "background": {
    "service_worker": "src/background/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": ["src/content/chessComContentScript.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://lichess.org/*"],
      "js": ["src/content/chessComContentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/library/library.html",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.chess.com/*", "https://lichess.org/*"]
}
